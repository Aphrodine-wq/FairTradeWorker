generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ────────────────────────────────────────────────────────

enum UserRole {
  CONTRACTOR
  HOMEOWNER
  SUBCONTRACTOR
}

enum SubJobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SubPaymentPath {
  CONTRACTOR_ESCROW
  PASSTHROUGH_ESCROW
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  roles         UserRole[]
  activeRole    UserRole
  name          String
  phone         String?
  avatar        String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contractor    Contractor?
  homeowner     Homeowner?
  subContractor SubContractor?
  sentMessages  Message[]     @relation("MessageSender")
  notifications Notification[]

  @@index([email])
}

model Contractor {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          String?
  bio              String?
  specialty        String?
  skills           String[]
  location         String?
  serviceRadius    Int?     @default(50)
  yearsExperience  Int?
  hourlyRate       Int?      // cents
  verified         Boolean  @default(false)
  licensed         Boolean  @default(false)
  insured          Boolean  @default(false)
  fairTradePromise Boolean  @default(false)
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  jobsCompleted    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  licenses         License[]
  insuranceCerts   InsuranceCert[]
  bids             Bid[]
  reviewsReceived  Review[]       @relation("ReviewTarget")
  reviewsGiven     Review[]       @relation("ReviewAuthor")
  conversations    ConversationParticipant[]
  qbConnection     QuickBooksConnection?
  payouts          Payout[]
  savedEstimates   SavedEstimate[]
  subJobs          SubJob[]

  @@index([location])
  @@index([specialty])
  @@index([verified])
}

model Homeowner {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location     String?
  propertyType String?
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs          Job[]
  reviewsGiven  Review[]  @relation("HomeownerReviewAuthor")
  conversations ConversationParticipant[]
  receipts      Receipt[]
}

// ── SubContractors ───────────────────────────────────────────────

model SubContractor {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          String?
  bio              String?
  specialty        String?
  skills           String[]
  location         String?
  serviceRadius    Int?     @default(50)
  yearsExperience  Int?
  hourlyRate       Int?      // cents
  verified         Boolean  @default(false)
  licensed         Boolean  @default(false)
  insured          Boolean  @default(false)
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  subJobsCompleted Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subBids          SubBid[]

  @@index([location])
  @@index([specialty])
}

model SubJob {
  id               String         @id @default(cuid())
  contractorId     String
  contractor       Contractor     @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  projectId        String
  milestoneLabel   String
  milestoneIndex   Int
  title            String
  description      String
  category         String
  skills           String[]
  location         String
  budgetMin        Int       // cents
  budgetMax        Int       // cents
  paymentPath      SubPaymentPath
  disclosedToOwner Boolean        @default(false)
  status           SubJobStatus   @default(OPEN)
  deadline         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  subBids          SubBid[]
  subPayout        SubPayout?

  @@index([contractorId])
  @@index([status])
  @@index([category])
}

model SubBid {
  id              String        @id @default(cuid())
  subJobId        String
  subJob          SubJob        @relation(fields: [subJobId], references: [id], onDelete: Cascade)
  subContractorId String
  subContractor   SubContractor @relation(fields: [subContractorId], references: [id], onDelete: Cascade)
  amount          Int           // cents
  message         String?
  timeline        String?
  status          BidStatus     @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([subJobId, subContractorId])
  @@index([subJobId])
  @@index([subContractorId])
}

model SubPayout {
  id              String         @id @default(cuid())
  subJobId        String         @unique
  subJob          SubJob         @relation(fields: [subJobId], references: [id], onDelete: Cascade)
  subContractorId String
  grossAmount     Int            // cents
  platformFee     Int            // cents
  netAmount       Int            // cents
  feePercent      Float          @default(5.0)
  paymentPath     SubPaymentPath
  status          String         @default("queued")
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ── Verification ─────────────────────────────────────────────────

model License {
  id             String    @id @default(cuid())
  contractorId   String
  contractor     Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  licenseNumber  String
  state          String
  type           String
  expirationDate DateTime?
  verified       Boolean   @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([contractorId])
}

model InsuranceCert {
  id             String    @id @default(cuid())
  contractorId   String
  contractor     Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  provider       String
  policyNumber   String
  coverageType   String
  coverageAmount Int?      // cents
  expirationDate DateTime
  fileUrl        String?
  verified       Boolean   @default(false)
  createdAt      DateTime  @default(now())

  @@index([contractorId])
}

// ── Jobs & Bidding ───────────────────────────────────────────────

enum JobStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
}

model Job {
  id                 String       @id @default(cuid())
  homeownerId        String
  homeowner          Homeowner    @relation(fields: [homeownerId], references: [id], onDelete: Cascade)
  title              String
  description        String
  detailedScope      String?
  category           String
  subcategory        String?
  budgetMin          Int?      // cents
  budgetMax          Int?      // cents
  location           String
  fullAddress        String?
  status             JobStatus    @default(OPEN)
  urgency            Urgency      @default(MEDIUM)
  propertyType       PropertyType @default(RESIDENTIAL)
  sqft               Int?
  yearBuilt          Int?
  deadline           DateTime?
  preferredStartDate DateTime?
  estimatedDuration  String?
  accessNotes        String?
  specialInstructions String?
  materialsProvided  Boolean      @default(false)
  permitsRequired    Boolean      @default(false)
  inspectionRequired Boolean      @default(false)
  insuranceClaim     Boolean      @default(false)
  tags               String[]
  viewCount          Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  photos             JobPhoto[]
  bids               Bid[]
  aiEstimate         AiEstimate?

  @@index([homeownerId])
  @@index([status])
  @@index([category])
  @@index([location])
  @@index([createdAt])
}

model JobPhoto {
  id      String @id @default(cuid())
  jobId   String
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url     String
  caption String?
  type    String @default("photo")

  @@index([jobId])
}

enum BidStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

model Bid {
  id           String    @id @default(cuid())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  amount       Int       // cents
  message      String?
  timeline     String?
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  invoice      Invoice?
  payout       Payout?

  @@unique([jobId, contractorId])
  @@index([jobId])
  @@index([contractorId])
  @@index([status])
}

// ── AI Estimation ────────────────────────────────────────────────

model AiEstimate {
  id              String   @id @default(cuid())
  jobId           String   @unique
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  estimateNumber  String   @unique
  estimateMin     Int      // cents
  estimateMax     Int      // cents
  estimateMid     Int      // cents
  confidence      Float
  breakdown       Json?
  lineItems       Json?
  materials       Json?
  laborHours      Float?
  laborCost       Int?     // cents
  materialCost    Int?     // cents
  equipmentCost   Int?     // cents
  subtotal        Int?     // cents
  overheadPercent Float?   @default(0.12)
  profitPercent   Float?   @default(0.15)
  contingencyPct  Float?   @default(0.08)
  total           Int?     // cents
  exclusions      String[]
  notes           String[]
  timelineWeeks   Int?
  pdfUrl          String?
  modelVersion    String   @default("constructionai-v4")
  regionFactor    Float?   @default(1.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  savedEstimates  SavedEstimate[]
}

model SavedEstimate {
  id              String      @id @default(cuid())
  contractorId    String
  contractor      Contractor  @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  aiEstimateId    String?
  aiEstimate      AiEstimate? @relation(fields: [aiEstimateId], references: [id])
  title           String
  projectType     String
  location        String
  sqft            Int?
  quality         String?     @default("mid-range")
  estimateData    Json
  pdfUrl          String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([contractorId])
}

// ── Messaging ────────────────────────────────────────────────────

model Conversation {
  id           String   @id @default(cuid())
  jobId        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([jobId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contractorId   String?
  contractor     Contractor?  @relation(fields: [contractorId], references: [id])
  homeownerId    String?
  homeowner      Homeowner?   @relation(fields: [homeownerId], references: [id])
  lastReadAt     DateTime?

  @@unique([conversationId, contractorId])
  @@unique([conversationId, homeownerId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ── Reviews ──────────────────────────────────────────────────────

model Review {
  id                    String      @id @default(cuid())
  contractorId          String
  contractor            Contractor  @relation("ReviewTarget", fields: [contractorId], references: [id], onDelete: Cascade)
  authorContractorId    String?
  authorContractor      Contractor? @relation("ReviewAuthor", fields: [authorContractorId], references: [id])
  authorHomeownerId     String?
  authorHomeowner       Homeowner?  @relation("HomeownerReviewAuthor", fields: [authorHomeownerId], references: [id])
  rating                Int
  text                  String?
  createdAt             DateTime    @default(now())

  @@index([contractorId])
}

// ── QuickBooks Integration ───────────────────────────────────────

model QuickBooksConnection {
  id            String    @id @default(cuid())
  contractorId  String    @unique
  contractor    Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  realmId       String
  accessToken   String
  refreshToken  String
  tokenExpiry        DateTime
  refreshTokenExpiry DateTime?
  companyName        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Invoice {
  id             String   @id @default(cuid())
  bidId          String   @unique
  bid            Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  qbInvoiceId    String?
  amount         Int      // cents
  status         String   @default("draft")
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  receipt        Receipt?
}

model Payout {
  id              String   @id @default(cuid())
  bidId           String   @unique
  bid             Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  contractorId    String
  contractor      Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  grossAmount     Int      // cents
  platformFee     Int      // cents
  netAmount       Int      // cents
  feePercent      Float    @default(5.0)
  qbVendorId      String?
  qbBillId        String?
  qbBillPaymentId String?
  status          String   @default("queued")
  failureReason   String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contractorId])
  @@index([status])
}

model Receipt {
  id             String   @id @default(cuid())
  invoiceId      String   @unique
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  homeownerId    String
  homeowner      Homeowner @relation(fields: [homeownerId], references: [id], onDelete: Cascade)
  receiptNumber  String   @unique
  grossAmount    Int      // cents
  platformFee    Int      // cents
  totalCharged   Int      // cents
  jobTitle       String
  contractorName String
  homeownerName  String
  lineItems      Json
  paidAt         DateTime
  createdAt      DateTime @default(now())

  @@index([homeownerId])
}

// ── Notifications ────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}
