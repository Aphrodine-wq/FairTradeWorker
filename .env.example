# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ftw?schema=public"

# ── Auth ─────────────────────────────────────────────────────────
# Next.js login route signs the `ftw-token` cookie with SECRET_KEY_BASE (if set) else JWT_SECRET.
# Edge middleware uses the same order — keep in sync with ftw-svc (Spring) when using SECRET_KEY_BASE.
JWT_SECRET="change-me-in-production"
# SECRET_KEY_BASE=

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── ftw-svc Backend ──────────────────────────────────────────────
# Browser + realtime client use NEXT_PUBLIC_REALTIME_URL. Optional FTW_SVC_URL overrides
# server-only proxies (e.g. /api/auth/login) when it should differ from the public URL.
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000
# FTW_SVC_URL=http://localhost:4000

# Optional: enable local fixture fallbacks while ftw-svc endpoints are still being implemented
NEXT_PUBLIC_DEV_USE_MOCK_DATA=false
# ── QuickBooks ───────────────────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
QB_SANDBOX=true
QB_WEBHOOK_VERIFIER_TOKEN=

# ── ConstructionAI ───────────────────────────────────────────────
# Local: http://localhost:8000/api/estimate
# Prod:  https://constructionai-api.onrender.com/api/estimate
CONSTRUCTIONAI_API_URL=http://localhost:8000/api/estimate

# ── Analytics (PostHog) ──────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Email (Resend) ───────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → create one
# Verify the fairtradeworker.com domain in Resend before going live
RESEND_API_KEY=
RESEND_FROM_EMAIL="FairTradeWorker <noreply@fairtradeworker.com>"
CONTACT_INBOX_EMAIL=hello@fairtradeworker.com

# ── OAuth (Google + Apple Sign-In) ───────────────────────────────
# Google: console.cloud.google.com → APIs & Services → Credentials
#   Create OAuth Client ID (Web application). Add authorized origins:
#   https://fairtradeworker.com, http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Apple: developer.apple.com → Identifiers → Services IDs (NOT bundle ID)
#   e.g. com.fairtradeworker.app.signin
NEXT_PUBLIC_APPLE_SERVICE_ID=
# Where Apple posts the form_post response (defaults to current origin /login)
NEXT_PUBLIC_APPLE_REDIRECT_URI=https://fairtradeworker.com/login

# ── Sentry (error monitoring) ────────────────────────────────────
# sentry.io → create Next.js project. Paste DSN below.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Used at build time to upload sourcemaps. Get from sentry.io → Auth Tokens.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
